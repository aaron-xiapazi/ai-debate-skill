# AI辩论Skill 环境变量配置

# 云物AI API Key（必填）
YUNWU_API_KEY=sk-your-key-here

# 云物AI API 地址（选填，默认 https://yunwu.ai/v1/chat/completions）
# YUNWU_API_URL=https://yunwu.ai/v1/chat/completions

# 火山引擎联网搜索 API Key（必填，豆包联网搜索用）
SEARCH_API_KEY=your-search-key-here

# 飞书群 Chat ID（飞书版必填）
# FEISHU_CHAT_ID=oc_xxx

# lark-cli 路径（飞书版选填）
# LARK_CLI=/usr/local/bin/lark-cli
